# ─── App Configuration (Required) ───────────────────────────────────────────
# OAuth client ID registered at developers.arcgis.com
VITE_ARCGIS_CLIENT_ID=

# ─── App Configuration (Optional) ───────────────────────────────────────────
# ArcGIS portal URL (default: https://www.arcgis.com)
# VITE_PORTAL_URL=https://www.arcgis.com

# Default WebMap item ID shown on first load
# VITE_MAP_ITEM_ID=

# Application title displayed in the header
# VITE_APP_TITLE="Agriculture Assistant"

# ArcGIS Online item ID (type: Web Mapping Application) for cross-browser
# config persistence. Create one and share it publicly for read access.
# VITE_CONFIG_ITEM_ID=

# ─── Azure Deployment (Required for deploy.sh) ─────────────────────────────
# Azure Container Registry name (just the name, not the full URL)
# AZURE_ACR_NAME=

# Azure resource group containing the Container App
# AZURE_RESOURCE_GROUP=

# Container App name
# AZURE_APP_NAME=

